# Server
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=account_balance_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME_TEST=account_balance_db_test

# Auth
JWT_SECRET=random_secret

# CORS (required in production)
# CORS_ORIGIN=https://your-frontend-domain.com

# Database SSL (required in production — path to RDS CA bundle)
# DB_SSL_CA=/path/to/rds-combined-ca-bundle.pem

# Auth cookie: this service reads the JWT from a cookie named "token".
# The auth service that issues the cookie MUST set these flags:
#   httpOnly: true
#   Secure: true (HTTPS only)
#   SameSite: Strict or Lax
